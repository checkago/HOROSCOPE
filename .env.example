DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,fizikazodiaka.ru,37.48.251.135
DJANGO_CSRF_TRUSTED_ORIGINS=https://fizikazodiaka.ru,http://fizikazodiaka.ru,https://37.48.251.135,http://37.48.251.135
# За HTTPS-терминацией на прокси: редирект HTTP→HTTPS в Django (если прокси не делает сам).
DJANGO_SECURE_SSL_REDIRECT=false
# HSTS только если весь сайт долго и стабильно отдаётся по HTTPS (ошибка сложно откатить).
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
PUBLIC_SITE_URL=https://fizikazodiaka.ru
DJANGO_SQLITE_PATH=
SITE_DOMAIN=fizikazodiaka.ru
