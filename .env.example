DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,fizikazodiaka.ru,37.48.251.135
DJANGO_CSRF_TRUSTED_ORIGINS=https://fizikazodiaka.ru,http://fizikazodiaka.ru,https://37.48.251.135,http://37.48.251.135
# За HTTPS-терминацией на прокси: редирект HTTP→HTTPS в Django (если прокси не делает сам).
DJANGO_SECURE_SSL_REDIRECT=false
# HSTS только если весь сайт долго и стабильно отдаётся по HTTPS (ошибка сложно откатить).
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
PUBLIC_SITE_URL=https://fizikazodiaka.ru
# В Docker задано через compose (DJANGO_SQLITE_PATH=/app/data/db.sqlite3); локально можно оставить пустым.
DJANGO_SQLITE_PATH=
# Пропустить полный re-import MD при старте контейнера (1 = не импортировать; данные уже в volume).
SKIP_MD_IMPORT=0
# Gunicorn (опционально)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
SITE_DOMAIN=fizikazodiaka.ru

# DeepSeek (опционально): если ключ не задан, генерация идёт локальным deterministic-алгоритмом.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=25
# Короткий таймаут отдельного запроса только для блока «Окна дня» (если полный прогноз по API не получен).
DEEPSEEK_TIMING_TIMEOUT_SECONDS=12
