DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,fizikazodiaka.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://fizikazodiaka.ru,http://fizikazodiaka.ru
PUBLIC_SITE_URL=https://fizikazodiaka.ru

# Let's Encrypt (docker nginx): для локальной разработки без HTTPS укажите DOMAIN=_
DOMAIN=fizikazodiaka.ru
CERTBOT_EMAIL=mfalcon@mail.ru
# Интервал между проверками certbot renew в секундах (7689600 ≈ 89 суток); фактическое продление — по политике Let's Encrypt
CERTBOT_RENEW_SLEEP_SEC=7689600
